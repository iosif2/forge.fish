[0.000, "o", "                                                     \r\u001b[29A\r\r\u001b[;m                                                                                                                \r\u001b[;1;38;5;110mCommand ❯ \u001b[0m\u001b[;1m\u001b[0m\u001b[;1m\u001b[0m\u001b[3B\r\u001b[;1;38;5;161;48;5;236m▌\u001b[0m\u001b[;48;5;236m \u001b[0m\u001b[;1;38;5;254;48;5;236mask                      AGENT    Research and investigation agent [alias for: sage]\u001b[0m\u001b[;m                          \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mforge                    AGENT    Perform technical development tasks\u001b[0m\u001b[;m                                         \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mmuse                     AGENT    Generate detailed implementation plans\u001b[0m\u001b[;m                                      \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mplan                     AGENT    Planning and strategy agent [alias for: muse]\u001b[0m\u001b[;m                               \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;msage                     AGENT    Research and analyze codebases\u001b[0m\u001b[;m                                              \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;magent                    COMMAND  Select and switch between agents [alias: a]\u001b[0m\u001b[;m                                 \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mclone                    COMMAND  Clone and manage conversation context\u001b[0m\u001b[;m                                       \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mcommit                   COMMAND  Directly commits AI generated commit message\u001b[0m\u001b[;m                                \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mcommit-preview           COMMAND  Previews AI generated commit message\u001b[0m\u001b[;m                                        \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mcompact                  COMMAND  Compact the conversation context\u001b[0m\u001b[;m                                            \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mconfig                   COMMAND  List current configuration values\u001b[0m\u001b[;m                                           \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mconfig-commit-model      COMMAND  Set the model used for commit message generation [alias: ccm]\u001b[0m\u001b[;m               \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mconfig-edit              COMMAND  Open the global forge config file (~/forge/.forge.toml) in an editor [alia··\u001b[0m\u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mconfig-model             COMMAND  Switch the models [alias: cm]\u001b[0m\u001b[;m                                               \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mconfig-provider          COMMAND  Switch the providers [alias: p, provider]\u001b[0m\u001b[;m                                   \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mconfig-reasoning-effort  COMMAND  Set the reasoning effort level in global config [alias: cre]\u001b[0m\u001b[;m                \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mconfig-reload            COMMAND  Reset all session overrides (model, provider, reasoning effort) to use glo··\u001b[0m\u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mconfig-suggest-model     COMMAND  Set the model used for command suggestion generation [alias: csm]\u001b[0m\u001b[;m           \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mconversation             COMMAND  List all conversations for the active workspace [alias: c]\u001b[0m\u001b[;m                  \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mconversation-rename      COMMAND  Rename a conversation by ID or interactively\u001b[0m\u001b[;m                                \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mcopy                     COMMAND  Copy last assistant message to clipboard as raw markdown\u001b[0m\u001b[;m                    \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mdoctor                   COMMAND  Run environment diagnostics for the shell plugin\u001b[0m\u001b[;m                            \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;mdump                     COMMAND  Save conversation as JSON or HTML (use /dump html for HTML format) [alias:··\u001b[0m\u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;medit                     COMMAND  Use an external editor to write a prompt\u001b[0m\u001b[;m                                    \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;menv                      COMMAND  Display environment information [alias: e]\u001b[0m\u001b[;m                                  \u001b[1B\r\u001b[;38;5;236m▌\u001b[0m\u001b[;m \u001b[;minfo                     "]
